#!/bin/bash
# multi-sync v3.1 2020-12-05

INSTALLDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
lua=$(which lua5.4)
if [ ! -z $lua ]; then
  export LUA_PATH="~/.luarocks/share/lua/5.4/?.lua;;"
  export LUA_CPATH="~/.luarocks/lib/lua/5.4/?.so;;"
else
  lua=$(which lua5.3)
  if [ ! -z $lua ]; then
    export LUA_PATH="~/.luarocks/share/lua/5.3/?.lua;;"
    export LUA_CPATH="~/.luarocks/lib/lua/5.3/?.so;;"
  else
    lua=$(which lua5.2)
    if [ ! -z $lua ]; then
      export LUA_PATH="~/.luarocks/share/lua/5.2/?.lua;;"
      export LUA_CPATH="~/.luarocks/lib/lua/5.2/?.so;;"
    fi
  fi
fi
ms=$INSTALLDIR/multi-sync.lua
export COMPUTERNAME=$(hostname)
export USERNAME=$USER
export CONFIGDIR="$HOME/.config"
[ ! -d $CONFIGDIR ] && mkdir $CONFIGDIR
[ ! -f $CONFIGDIR/multi-sync.sqlite3 ] && cp $INSTALLDIR/multi-sync.sqlite3 $CONFIGDIR
[ ! -f $CONFIGDIR/multi-sync-config.lua ] && cp $INSTALLDIR/multi-sync-config.lua $CONFIGDIR
# If Lua and multi-sync.lua are both found, execute
if [[ -f "$lua" && -f "$ms" ]]; then
  $lua $ms "$@"
  exit $?
else
  echo "Lua and/or multi-sync.lua not found"
  exit 1
fi
